# Nimble API (nimbleway.com)
NIMBLE_API_KEY=your-nimble-api-key

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=event_scheduler

# LLM (any OpenAI-compatible provider — OpenCode Zen, ZenMux, Groq, etc.)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_PARSE_MODEL=deepseek-v4-flash-free
LLM_RERANK_MODEL=deepseek-v4-flash-free

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Feedback API
FEEDBACK_API_BASE_URL=http://localhost:8000
